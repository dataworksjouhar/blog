---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  // External showpieces live in /public, so skip them here.
  return posts
    .filter((p) => !p.data.external)
    .map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, category, level } = post.data;
const fmtDate = date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const backHref = `/${category}`;
const backLabel = category.charAt(0).toUpperCase() + category.slice(1);
---
<BaseLayout title={`${title} — Mohammed Jouhar`} description={description}>
  <article class="article">
    <div class="wrap">
      <div class="article-head">
        <div class="eyebrow">{fmtDate}{level ? ` · ${level}` : ''}</div>
        <h1>{title}</h1>
        <p class="sub">{description}</p>
      </div>
      <div class="prose">
        <Content />
        <a class="back-link" href={backHref}>← Back to {backLabel}</a>
      </div>
    </div>
  </article>
</BaseLayout>
